{
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "doctrine/orm": "^3.0",
    "doctrine/doctrine-bundle": "^2.12",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "lexik/jwt-authentication-bundle": "^2.20",
    "nelmio/cors-bundle": "^2.4",
    "symfony/flex": "^2.4",
    "symfony/framework-bundle": "7.4.*",
    "symfony/monolog-bundle": "^3.0",
    "symfony/runtime": "7.4.*",
    "symfony/security-bundle": "7.4.*",
    "symfony/serializer": "7.4.*",
    "symfony/uid": "7.4.*",
    "symfony/var-exporter": "7.4.*",
    "symfony/validator": "7.4.*",
    "symfony/yaml": "7.4.*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "symfony/dotenv": "7.4.*",
    "symfony/maker-bundle": "^1.57"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  }
}
